// App -> agents events, published on the `st.agent.events` channel (ipc::route
// 1->N, pub-sub). The AgentControlController is a MessageListener that republishes
// observed message-bus changes as Events, so an agent can react without polling.
// See context/DESIGN_AGENT_UI_CONTROL.md.

include "agent_common.fbs";

namespace Sourcetrail.Agent;

table NodesActivated   { nodes: [NodeRef]; }                     // MessageActivateNodes
table EdgeActivated    { edge: EdgeRef; }                        // MessageActivateEdge
table FileActivated    { file_path: string; }                   // MessageActivateFile
table SearchCompleted  { matches: [SearchMatch]; }              // MessageSearch
table FocusChanged     { view: ViewKind = Unknown; }            // MessageFocusView
table IndexingStarted  { }                                      // MessageIndexingStarted
table IndexingProgress { files_done: uint32; files_total: uint32; }  // MessageIndexingStatus
table IndexingFinished { succeeded: bool; }                     // MessageIndexingFinished / Interrupted
table ErrorCountChanged { total: uint32; fatal: uint32; }       // MessageErrorCountUpdate
table StatusChanged    { text: string; }                        // MessageStatus
table AppStateChanged  { state: AppState = NoProject; }         // the FSM transitioned
table TabsChanged      { tabs: [TabInfo]; }                     // MessageTabsChanged (full snapshot)

// Closed-loop ack for a command, correlated by the command's request_id. ok=false
// with a message covers both failures and state-gated rejections (message begins
// "rejected: ..."). Every command emits one; GetUiState additionally replies with a
// UiStateEnvelope on st.agent.state.
table CommandResult { request_id: uint64; ok: bool; message: string; }

// The act-and-observe barrier: emitted once the synchronous message-bus fan-out a
// command triggered has drained (the queue went idle after it), so a subsequent
// GetUiState observes the *settled* state. Correlated by request_id. Asynchronous
// work (indexing, project load) settles at its terminal event
// (AppStateChanged/IndexingFinished) instead. See DESIGN_AGENT_UI_CONTROL.md.
table Settled { request_id: uint64; }

// Forwarded log line — from Sourcetrail's LogManager (source App) or Qt's
// categorized logging (source Qt, via qInstallMessageHandler). Gated by the agent
// log filter (SetLogFilter). LogLevel/LogSource live in agent_common.fbs (shared
// with the SetLogFilter command). See DESIGN_AGENT_UI_CONTROL.md.
table LogEvent {
    level:    LogLevel;
    source:   LogSource;
    category: string;   // Qt logging category (empty for App logs)
    message:  string;
    file:     string;
    function: string;
    line:     uint32;
}

union Event {
    NodesActivated,
    EdgeActivated,
    FileActivated,
    SearchCompleted,
    FocusChanged,
    IndexingStarted,
    IndexingProgress,
    IndexingFinished,
    ErrorCountChanged,
    StatusChanged,
    AppStateChanged,
    TabsChanged,
    CommandResult,
    Settled,
    LogEvent,
}

// One message on `st.agent.events`. `seq` is a per-session monotonic counter so a
// late-subscribing agent can detect gaps.
table EventEnvelope {
    seq:          uint64;
    timestamp_ms: uint64;
    event:        Event;
}

root_type EventEnvelope;
