{
	"version": 4,
	"configurePresets": [
		{
			"hidden": true,
			"name": "default-presets",
			"generator": "Ninja",
			"warnings": {
				"dev": false,
				"uninitialized": false
			},
			"binaryDir": "${sourceDir}/.build/${presetName}"
		},
		{
			"hidden": true,
			"name": "dbg-presets",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"CMAKE_VERBOSE_MAKEFILE": "TRUE",
				"CMAKE_EXPORT_COMPILE_COMMANDS": "TRUE"
			}
		},
		{
			"hidden": true,
			"name": "rel-presets",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release",
				"CMAKE_VERBOSE_MAKEFILE": "FALSE",
				"CMAKE_EXPORT_COMPILE_COMMANDS": "TRUE"
			}
		},
		{
			"hidden": true,
			"name": "reldbg-presets",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "RelWithDebInfo",
				"CMAKE_VERBOSE_MAKEFILE": "FALSE",
				"CMAKE_EXPORT_COMPILE_COMMANDS": "TRUE"
			}
		},
		{
			"hidden": true,
			"name": "vcpkg-default-presets",
			"inherits": [
				"default-presets"
			],
			"cacheVariables": {
				"CMAKE_TOOLCHAIN_FILE": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
				"VCPKG_TARGET_TRIPLET": "x64-arm64-linux-windows-osx-static-md"
			}
		},
		{
			"hidden": true,
			"name": "apple-clang-presets",
			"cacheVariables": {
				"CMAKE_C_COMPILER": "clang",
				"CMAKE_CXX_COMPILER": "clang++",
				"BUILD_SWIFT_LANGUAGE_PACKAGE": "ON"
			}
		},
		{
			"hidden": true,
			"name": "llvm-clang-presets",
			"cacheVariables": {
				"VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake-toolchains/llvm-clang-macos.cmake",
				"BUILD_SWIFT_LANGUAGE_PACKAGE": "ON"
			}
		},
		{
			"hidden": true,
			"name": "sourcetrail-presets",
			"cacheVariables": {
				"BUILD_CXX_LANGUAGE_PACKAGE": "ON",
				"BUILD_RUST_LANGUAGE_PACKAGE": "ON",
				"BUILD_UNIT_TESTS_PACKAGE": "ON"
			}
		},
		{
			"hidden": true,
			"name": "vcpkg-llvm-presets",
			"cacheVariables": {
				"VCPKG_MANIFEST_FEATURES": "cxx-indexer"
			}
		},
		{
			"hidden": true,
			"name": "windows-msvc-presets",
			"description": "MSVC + Ninja for the Windows C++20-modules bring-up. Run scripts/win/Init-ModulesEnv.ps1 first (or use a 'x64 Native Tools Command Prompt for VS 18') so cl.exe and the pinned module-capable toolset (14.51.36231) are on PATH. Modules stay opt-in: add -D SOURCETRAIL_CXX_MODULES=ON.",
			"cacheVariables": {
				"CMAKE_C_COMPILER": "cl",
				"CMAKE_CXX_COMPILER": "cl"
			},
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Windows"
			}
		},
		{
			"hidden": true,
			"name": "windows-clang-cl-presets",
			"description": "clang-cl + Ninja on Windows: clang's frontend with the MSVC ABI/STL. Unlike cl.exe, clang-cl has neither the QMetaType-IFC nor the glaze/toml ICE, so it builds the full module graph (the frontier cut is cl.exe-only). Run scripts/win/Init-ModulesEnv.ps1 for the MSVC env and put the desired LLVM bin (>=16; 22.1.8 matches the macOS build) first on PATH so 'clang-cl' resolves to it. Modules opt-in: -D SOURCETRAIL_CXX_MODULES=ON. NOTE: 'environment' sets CMAKE_NINJA_FORCE_RESPONSE_FILE=1 -- clang-scan-deps runs as `cmd /C \"clang-scan-deps -- clang-cl <~80 -I paths> > tmp && rename\"`, which overflows cmd.exe's 8191-char limit ('The command line is too long') on the big module targets; response files keep the scan commands short. cl.exe's integrated /scanDependencies does not need this.",
			"cacheVariables": {
				"CMAKE_C_COMPILER": "clang-cl",
				"CMAKE_CXX_COMPILER": "clang-cl"
			},
			"environment": {
				"CMAKE_NINJA_FORCE_RESPONSE_FILE": "1"
			},
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Windows"
			}
		},
		{
			"name": "dbg",
			"inherits": [
				"dbg-presets",
				"vcpkg-default-presets",
				"sourcetrail-presets"
			]
		},
		{
			"name": "rel",
			"inherits": [
				"rel-presets",
				"vcpkg-default-presets",
				"sourcetrail-presets"
			]
		},
		{
			"name": "rel-cxx",
			"inherits": [
				"rel",
				"vcpkg-llvm-presets"
			]
		},
		{
			"name": "reldbg",
			"inherits": [
				"reldbg-presets",
				"vcpkg-default-presets",
				"sourcetrail-presets"
			]
		},
		{
			"name": "apple-clang-dbg",
			"inherits": [
				"dbg",
				"apple-clang-presets"
			]
		},
		{
			"name": "apple-clang-rel",
			"inherits": [
				"rel",
				"apple-clang-presets"
			]
		},
		{
			"name": "apple-clang-reldbg",
			"inherits": [
				"reldbg",
				"apple-clang-presets"
			]
		},
		{
			"name": "llvm-clang-dbg",
			"inherits": [
				"dbg",
				"llvm-clang-presets"
			]
		},
		{
			"name": "llvm-clang-rel",
			"inherits": [
				"rel",
				"llvm-clang-presets"
			]
		},
		{
			"name": "llvm-clang-reldbg",
			"inherits": [
				"reldbg",
				"llvm-clang-presets"
			]
		},
		{
			"name": "windows-msvc-dbg",
			"inherits": [
				"dbg",
				"windows-msvc-presets"
			]
		},
		{
			"name": "windows-msvc-rel",
			"inherits": [
				"rel",
				"windows-msvc-presets"
			]
		},
		{
			"name": "windows-msvc-reldbg",
			"inherits": [
				"reldbg",
				"windows-msvc-presets"
			]
		},
		{
			"name": "windows-clang-cl-dbg",
			"inherits": [
				"dbg",
				"windows-clang-cl-presets"
			]
		},
		{
			"name": "windows-clang-cl-rel",
			"inherits": [
				"rel",
				"windows-clang-cl-presets"
			]
		}
	]
}