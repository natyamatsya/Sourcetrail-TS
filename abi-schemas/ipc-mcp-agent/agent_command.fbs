// Agent -> app commands, sent on the `st.agent.cmd` channel (thoth::route N->1).
// Each command maps to a Message<T> the AgentControlController dispatches onto the
// message bus. See context/DESIGN_AGENT_UI_CONTROL.md.

include "agent_common.fbs";

namespace Sourcetrail.Agent;

table LoadProject   { project_file_path: string; refresh_mode: RefreshMode = None; }  // MessageLoadProject
table Search        { query: string; }                                               // MessageFind / MessageSearch
table ActivateNode  { serialized_name: string; node_id: uint64 = 0; }                 // MessageActivateNodes
table ActivateEdge  { source_serialized_name: string; target_serialized_name: string; edge_type: int32; }  // MessageActivateEdge
table ActivateFile  { file_path: string; }                                            // MessageActivateFile
table ActivateTab   { tab_id: uint64; }                                               // MessageTabActivate
table ScrollToLine  { file_path: string; line: uint32; }                              // MessageScrollToLine
table HistoryBack    {}                                                               // MessageHistoryUndo
table HistoryForward {}                                                               // MessageHistoryRedo
table CreateBookmark { name: string; comment: string; node_serialized_name: string; } // MessageBookmarkCreate

// Structural control: invoke an accessible action (or set text) on the element
// addressed by `target` (the same ElementRef the snapshot emits). Resolved to a
// live QAccessibleInterface by QtUiControl on the GUI thread. See
// DESIGN_AGENT_UI_CONTROL.md (Structural control).
// expect_hash (0 = off): optimistic control — the app re-resolves the target and,
// if its structural hash differs from expect_hash, drops with "element changed
// since snapshot". Pass a snapshot node's `hash`.
table InvokeAction { target: ElementRef; action: string; text: string; expect_hash: uint64 = 0; }

// Screenshot a single element by its ref -> FrameEnvelope on st.agent.frames,
// correlated by request_id. include_properties additionally replies with a
// single-node UiSnapshot (the element's UiNode) on st.agent.snapshot.
table CaptureElement { target: ElementRef; format: FrameFormat = Png; include_properties: bool = false; expect_hash: uint64 = 0; }

// Server-side element selection: evaluate a JSONPath (RFC 9535, qt-json-query) over
// the UI snapshot at the source. Reply is a UiSnapshot on st.agent.snapshot whose
// roots are the matched elements (each with its ref) — no full-tree transfer.
table QueryUi { jsonpath: string; }

// Configure agent log forwarding. qt_rules drives QLoggingCategory::setFilterRules
// (controls Qt emission at the source). event_pattern is a regex the sink matches
// against "category: message" before raising a LogEvent (empty = forward all at/above
// min_level). min_level is the floor across both sources. See DESIGN_AGENT_UI_CONTROL.md.
table SetLogFilter { qt_rules: string; event_pattern: string; min_level: LogLevel = Warning; }

// Handshake: reply is an AppInfo event on st.agent.events, correlated by request_id,
// carrying the app's ProtocolVersion.Current + build identity. The bridge issues this
// on connect to detect protocol skew (see DESIGN_AGENT_UI_CONTROL.md). Like GetUiState
// it also emits a CommandResult ack.
table GetInfo { }                                                                     // -> AppInfo event on st.agent.events

// Requests: the reply is published on another channel, correlated by request_id.
table GetUiState { }                                                                  // -> UiStateEnvelope on st.agent.state
table GetFrame   { format: FrameFormat = Png; max_width: uint32 = 0; }                // -> FrameEnvelope on st.agent.frames
table GetSnapshot { format: SnapshotFormat = Accessibility; }                         // -> UiSnapshot on st.agent.snapshot

union Command {
    LoadProject,
    Search,
    ActivateNode,
    ActivateEdge,
    ActivateFile,
    ActivateTab,
    ScrollToLine,
    HistoryBack,
    HistoryForward,
    CreateBookmark,
    GetUiState,
    GetFrame,
    GetSnapshot,
    InvokeAction,
    CaptureElement,
    QueryUi,
    SetLogFilter,
    GetInfo,
}

// One message on `st.agent.cmd`. `request_id` correlates a later reply
// (UiStateEnvelope / FrameEnvelope) or ack.
table CommandEnvelope {
    request_id: uint64;
    command:    Command;
}

root_type CommandEnvelope;
